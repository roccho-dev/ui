{"version":"v0.9","updateComponents":{"surfaceId":"purpose-atlas","components":[{"id":"root","component":"A2uiSduiSurface","document":{"styles":{"css":":host{display:block;width:100%;height:100%;overflow:hidden;background:#050915;color:#eef5ff;font-family:Inter,ui-sans-serif,system-ui,sans-serif}.sdui-app{position:fixed;inset:0;display:grid;grid-template-rows:minmax(0,1fr)auto;gap:8px;padding:8px;background:linear-gradient(180deg,#081020,#040711)}.sdui-shell{min-width:0;min-height:0;display:grid;grid-template-columns:minmax(0,1fr)minmax(240px,300px);gap:8px}.sdui-stage{position:relative;min-width:0;min-height:0;overflow:hidden;border:1px solid rgba(161,188,236,.18);border-radius:16px;background:#071222}.sdui-stage-port,.sdui-stage canvas{position:absolute;inset:0;width:100%;height:100%;display:block}.sdui-hud{position:absolute;z-index:3;left:10px;top:10px;display:flex;gap:6px;flex-wrap:wrap;pointer-events:none}.sdui-chip,.sdui-pill{min-height:25px;padding:4px 8px;border:1px solid rgba(165,194,242,.16);border-radius:999px;background:rgba(5,10,19,.78);color:#b8cae9;font-size:10px;font-weight:850;white-space:nowrap}.sdui-panel,.sdui-rail{border:1px solid rgba(161,188,236,.18);border-radius:16px;background:rgba(9,16,30,.94);box-shadow:0 16px 42px rgba(0,0,0,.24)}.sdui-panel{min-height:0;overflow:auto;padding:12px;display:grid;align-content:start;gap:12px}.sdui-kicker{color:#7f93b9;font-size:10px;font-weight:900;letter-spacing:.09em;text-transform:uppercase}.sdui-title{display:block;font-size:20px;font-weight:900}.sdui-copy{color:#c5d3ec;font-size:12px;line-height:1.45}.sdui-row,.sdui-segmented,.sdui-transport,.sdui-zoom{display:flex;gap:6px;flex-wrap:wrap}.sdui-segmented,.sdui-transport,.sdui-zoom{padding:3px;border:1px solid rgba(255,255,255,.08);border-radius:12px}button{font:inherit;color:inherit;min-width:34px;min-height:32px;border:1px solid transparent;border-radius:9px;background:transparent;font-weight:850;cursor:pointer}.sdui-segmented button[aria-selected=true