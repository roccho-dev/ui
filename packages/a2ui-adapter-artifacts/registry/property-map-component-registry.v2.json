{
  "kind": "a2ui.componentRegistry.v2",
  "id": "property-map.zip-parity.v1",
  "inherits": [
    "shared-sdui-registry.geo-map.v1"
  ],
  "purpose": "Reproduce zip property-map UI using A2UI-only registry, SDUI surface, data model, and GeoMapPort.",
  "authority": {
    "sourceAuthority": [
      "registry/property-map-component-registry.v2.json",
      "a2ui/property-map-zip-parity.surface.v1.jsonl",
      "data/property-map-zip-parity.seed.v1.json",
      "runtime/geo-map-port.js"
    ],
    "notAuthority": [
      "reference/zip-visual-oracle/**",
      "generated HTML",
      "screenshots",
      "proof reports"
    ]
  },
  "ports": [
    {
      "id": "geoMap",
      "implementation": "GeoMapPort",
      "allowedLibrary": "Leaflet-compatible port object",
      "libraryBoundary": "Map library calls are allowed only inside GeoMapPort"
    },
    {
      "id": "atlasStage",
      "implementation": "AtlasStagePort"
    }
  ],
  "nodeTypes": [
    "box",
    "text",
    "button",
    "repeat",
    "metric",
    "table",
    "tabs",
    "viewSwitch",
    "component",
    "port",
    "jsonEditor"
  ],
  "components": [
    {
      "id": "MapSheetShell",
      "family": "layout",
      "props": [
        "titlePath",
        "tabsPath",
        "activeViewPath"
      ],
      "slots": [
        "map",
        "sheet"
      ]
    },
    {
      "id": "SheetTabs",
      "family": "navigation",
      "props": [
        "tabsPath",
        "activeViewPath",
        "onChangeAction"
      ]
    },
    {
      "id": "ViewStack",
      "family": "layout",
      "props": [
        "viewsPath",
        "activeViewPath"
      ]
    },
    {
      "id": "CompareControls",
      "family": "zip-view-component"
    },
    {
      "id": "ContentBlocks",
      "family": "zip-view-component"
    },
    {
      "id": "DataEditor",
      "family": "zip-view-component"
    },
    {
      "id": "DecisionPanel",
      "family": "zip-view-component"
    },
    {
      "id": "FocusHero",
      "family": "zip-view-component"
    },
    {
      "id": "FocusMetrics",
      "family": "zip-view-component"
    },
    {
      "id": "FocusRegionalAccess",
      "family": "zip-view-component"
    },
    {
      "id": "GeneratedHighlights",
      "family": "zip-view-component"
    },
    {
      "id": "InitialCostPanel",
      "family": "zip-view-component"
    },
    {
      "id": "InitialCostTable",
      "family": "zip-view-component"
    },
    {
      "id": "JudgementBands",
      "family": "zip-view-component"
    },
    {
      "id": "MinimumActiveConditions",
      "family": "zip-view-component"
    },
    {
      "id": "NearbyPropertyRail",
      "family": "zip-view-component"
    },
    {
      "id": "PoiGrid",
      "family": "zip-view-component"
    },
    {
      "id": "PrincipleChips",
      "family": "zip-view-component"
    },
    {
      "id": "PrinciplesPanel",
      "family": "zip-view-component"
    },
    {
      "id": "PropertyTable",
      "family": "zip-view-component"
    },
    {
      "id": "QualityGateTable",
      "family": "zip-view-component"
    },
    {
      "id": "QuarantineTable",
      "family": "zip-view-component"
    },
    {
      "id": "RegionalAccessMatrix",
      "family": "zip-view-component"
    },
    {
      "id": "RequirementMatrix",
      "family": "zip-view-component"
    },
    {
      "id": "SduiEditor",
      "family": "zip-view-component"
    },
    {
      "id": "SourceAuditPanel",
      "family": "zip-view-component"
    },
    {
      "id": "WatchlistTable",
      "family": "zip-view-component"
    }
  ],
  "actions": [
    "property.select",
    "ui.view.set",
    "ui.sheet.toggle",
    "ui.filter.set",
    "ui.data.apply",
    "ui.sdui.apply",
    "geoMap.marker.click"
  ],
  "canonicalUi": {
    "visibleHtml": "preview/index.html",
    "forbiddenVisibleHtml": [
      "preview/file-open-offline-proof.html",
      "preview/file-open-cdn-fixed.html"
    ],
    "targetVisualReference": "reference/zip-visual-oracle/visual-contract.json",
    "markerStyle": "zip-house-label",
    "sheetStyle": "zip-tabbed-bottom-sheet"
  }
}
